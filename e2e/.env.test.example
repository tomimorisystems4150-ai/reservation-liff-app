# E2Eテスト設定ファイル
# このファイルを .env.test としてコピーして実際の値を設定してください
# .env.test は .gitignore に含まれています

# テスト用LIFFアプリのURL（GitHub Pages）
LIFF_BASE_URL=https://[your-org].github.io/reservation-liff-app

# テスト用GAS WebアプリURL
GAS_API_URL=https://script.google.com/macros/s/[TEST_DEPLOYMENT_ID]/exec

# テスト用LIFF ID（LINE DevelopersコンソールのLIFF ID）
LIFF_ID=[YOUR_TEST_LIFF_ID]

# テスト用LIFFページURL（gasApiUrlとliffIdを含む完全URL）
# 例: https://example.github.io/reservation-liff-app/liff.html?gasApiUrl=https%3A%2F%2F...&liffId=...
LIFF_FULL_URL=[FULL_LIFF_URL_WITH_PARAMS]

# 管理画面URL（スクリーンショット取得用）
# GAS_API_URL と同じURL（settings.htmlが表示される）
GAS_ADMIN_URL=https://script.google.com/macros/s/[DEPLOYMENT_ID]/exec
